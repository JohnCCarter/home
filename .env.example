# Use "common" for personal Microsoft accounts (@hotmail.com / @outlook.com).
# Use your tenant GUID for work/school accounts only.
AZURE_TENANT_ID=common
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# Optional Google OAuth config for future Google Calendar read-only auth.
# Leave commented out unless you actually use /auth/google — Microsoft works without these.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

CONTROL_PLANE_API_KEY=

# References to OpenAI Tunnel IDs
TUNNEL_ID_HOME=
TUNNEL_ID_WORK=